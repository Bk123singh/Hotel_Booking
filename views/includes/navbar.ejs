<style>
  /* Search input & button */
  .search-input {
    border-radius: 25px;
    padding: 0.5rem 1rem;
    font-size: 1rem;
  }

  .search-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0.5rem 1.2rem;
    font-size: 1rem;
    white-space: nowrap;
  }

  .search-btn i {
    margin-right: 0.5rem;
  }

  .search-btn:hover {
    background-color: #e63946;
    color: #fff;
  }

  /* Navbar Auth Buttons */
  .nav-auth {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .nav-auth .nav-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 25px;
    padding: 0.4rem 1rem;
    font-weight: 600;
    transition: all 0.2s ease-in-out;
    text-decoration: none;
  }

  .nav-auth .signup-btn {
    background-color: #fe424d;
    color: #fff !important;
  }

  .nav-auth .signup-btn:hover {
    background-color: #e63946;
    color: #fff !important;
  }

  .nav-auth .login-btn {
    border: 2px solid #fe424d;
    color: #fe424d !important;
    background: transparent;
  }

  .nav-auth .login-btn:hover {
    background-color: #fe424d;
    color: #fff !important;
  }

  .nav-auth .logout-btn {
    border: 2px solid #6c757d;
    color: #6c757d !important;
    background: transparent;
  }

  .nav-auth .logout-btn:hover {
    background-color: #6c757d;
    color: #fff !important;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container">
    <!-- Brand -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i> Roamly
    </a>

    <!-- Toggler button -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar content -->
   

      <!-- Search bar -->
      <div class="navbar-nav mx-auto mt-2 mt-md-0">
        <form class="d-flex" action="/search" method="GET">
          <input class="form-control me-2 search-input" name="q" type="search" placeholder="Search destinations">
          <button class="btn search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i> Search
          </button>
        </form>
      </div>

      <!-- Auth buttons -->
      <div class="navbar-nav ms-auto nav-auth mt-2 mt-md-0">
        <a class="nav-link" href="/listings/new">
          <i class="fa-solid fa-house-chimney"></i> Add your home
        </a>

        <% if (!currUser) { %>
          <a href="/signup" class="nav-link signup-btn">
            <i class="fa-solid fa-user-plus"></i> Sign Up
          </a>
          <a href="/login" class="nav-link login-btn">
            <i class="fa-solid fa-right-to-bracket"></i> Log In
          </a>
        <% } else { %>
         
          <a class="nav-link logout-btn" href="/logout">
            <i class="fa-solid fa-right-from-bracket"></i> Log Out
          </a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
  