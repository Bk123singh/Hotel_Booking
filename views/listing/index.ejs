<%- layout("/layout/boilerplate") %>
  <% if (success && success.length> 0) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% } %>


      <body>
        <!-- Filters Section -->
        <div id="filters">
          <div class="container">
            <div class="row align-items-center">

              <!-- Filters  -->
              <div class="col-12 col-lg-10">
                <div class="filters-scroll">
                  <div class="d-flex gap-3 pb-2 flex-wrap">
                    <div class="filter active" data-filter="trending">
                      <i class="fa-solid fa-fire"></i>
                      <p>Trending</p>
                    </div>
                    <div class="filter" data-filter="rooms">
                      <i class="fa-solid fa-bed"></i>
                      <p>Rooms</p>
                    </div>
                    <div class="filter" data-filter="cities">
                      <i class="fa-solid fa-mountain-city"></i>
                      <p>Iconic cities</p>
                    </div>
                    <div class="filter" data-filter="mountain">
                      <i class="fa-solid fa-mountain"></i>
                      <p>Mountain</p>
                    </div>
                    <div class="filter" data-filter="castles">
                      <i class="fa-brands fa-fort-awesome"></i>
                      <p>Castles</p>
                    </div>
                    <div class="filter" data-filter="arctic">
                      <i class="fa-solid fa-snowflake"></i>
                      <p>Arctic</p>
                    </div>
                    <div class="filter" data-filter="camping">
                      <i class="fa-solid fa-campground"></i>
                      <p>Camping</p>
                    </div>
                    <div class="filter" data-filter="farms">
                      <i class="fa-solid fa-cow"></i>
                      <p>Farms</p>
                    </div>
                    <div class="filter" data-filter="domes">
                      <i class="fa-solid fa-igloo"></i>
                      <p>Domes</p>
                    </div>
                    <div class="filter" data-filter="boats">
                      <i class="fa-solid fa-ship"></i>
                      <p>Boats</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Tax Toggle  -->
              <div class="col-12 col-lg-2 text-lg-end mt-2 mt-lg-0">
                <div class="form-check form-switch d-flex justify-content-lg-end justify-content-start">
                  <input class="form-check-input me-2" type="checkbox" id="switchCheckDefault">
                  <label class="form-check-label text-nowrap" for="switchCheckDefault">
                    Display Total After Taxes
                  </label>
                </div>
              </div>

            </div>
          </div>
        </div>




    
        <!-- <h1>All listings</h1> -->
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-3">
          <% for( datas of data){ %>
            <div class="col">
              <a href="/listings/<%= datas._id %>" class="listings-link text-decoration-none">
                <div class="card listing-card h-100" style="position: relative;">

                  <!--  Like Button -->
                  <form action="/listings/<%= datas._id %>/like" method="POST" class="like-form">
                    <button type="submit" class="like-btn">
                      <i
                        class="<%= datas.likes.some(user => user.equals(user?._id)) ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                    </button>
                  </form>

                  <img src="<%= datas.Image.url %>" class="card-img-top card_image" alt="..." style="height: 18rem;">

                  <div class="card-body">
                    <h5 class="card-title">
                      <%= datas.title %>
                    </h5>

                    <!-- Show Like Count -->
                    <!-- <p><%= datas.likes.length %> likes</p> -->

                    <p class="card-text price-line">
                      &#x20b9; <%= datas.price %>/night &nbsp;
                        <span class="tax-info">+18% GST</span>
                    </p>
                  </div>
                </div>
              </a>
            </div>
            <% } %>
        </div>

        <script>
          let taxSwitch = document.getElementById("switchCheckDefault");
          taxSwitch.addEventListener("click", () => {
            let taxinfo = document.getElementsByClassName("tax-info")
            for (info of taxinfo) {
              if (info.style.display != 'inline') {
                info.style.display = 'inline'
              } else {
                info.style.display = 'none';
              }
            }
          })

        </script>

      </body>