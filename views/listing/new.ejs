<%- layout("/layout/boilerplate") %>

    <br>
    <h2 class="text-center"><b>Create a New Listings</b></h2>
    <div class="container-md col-6">
        <form method="post" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
            <div class="mb-3">
                <label for="title" class="form-label ">Title</label>
                <input type="text" name="listing[title]" id="title" placeholder="Add a catchy title"
                    class="form-control mb-3" required>
                    <div class="valid-feedback">
                        Looks good !
                    </div>
            </div>


            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" id="" class="form-control mb-3" required></textarea>
                <div class="invalid-feedback">
                    pleaser shoud valid Description
                </div>
            </div>


            <div class="mb-3">
                <label for="image" class="form-label">Upload Image</label>
                <input type="file" name="listing[image]" class="form-control mb-3" required>
            </div>
            <div class="mb-3">
                <label for="keyFeatures" class="form-label">Key Features</label>
                <input type="text" name="listing[keyFeatures][]" class="form-control mb-2"
                    placeholder="Feature 1 (e.g. Free WiFi)">
                <input type="text" name="listing[keyFeatures][]" class="form-control mb-2"
                    placeholder="Feature 2 (e.g. Parking)">
                <input type="text" name="listing[keyFeatures][]" class="form-control mb-2"
                    placeholder="Feature 3 (e.g. Air Conditioning)">
                <small class="form-text text-muted">Add as many features as you like</small>
            </div>

            <div class="row">
                <div class="mb-3 col-md-6">
                    <label for="price" class="form-label">Price</label>
                    <input type="number" name="listing[price]" id="" placeholder="1200" class="form-control mb-3"
                        required>
                    <div class="invalid-feedback">
                        Please should be enter valid price
                    </div>
                </div>

                <div class="mb-3 col-md-6">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" id="" placeholder="Jaipur,Rajasthan"
                        class="form-control mb-3" required>
                    <div class="invalid-feedback">
                        Please shoud be enter a valid location.
                    </div>
                </div>
            </div>


            <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="listing[country]" id="" placeholder="India" class="form-control mb-3" required>
                <div class="invalid-feedback">
                    Please should be enter a valid country.
                </div>
            </div>


            <button class="btn btn-primary">ADD</button>
            <br><br>
        </form>

    </div>